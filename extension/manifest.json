{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "0.2.0",
  "description": "__MSG_extensionDescription__",
  "default_locale": "zh_CN",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://www.raidbots.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.raidbots.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data/item-names.json",
        "data/item-search-index.json"
      ],
      "matches": [
        "https://www.raidbots.com/*"
      ]
    }
  ]
}
