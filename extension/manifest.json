{
  "manifest_version": 3,
  "name": "Raidbots 中文翻译",
  "version": "0.1.0",
  "description": "将 raidbots.com 中的物品、附魔、宝石和增益等内容翻译为中文。",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "https://www.raidbots.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.raidbots.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data/item-names.json",
        "data/item-search-index.json"
      ],
      "matches": [
        "https://www.raidbots.com/*"
      ]
    }
  ]
}
