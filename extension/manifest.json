{
  "manifest_version": 3,
  "name": "Raidbots Item Name CN",
  "version": "0.1.0",
  "description": "Translate item names on raidbots.com from English to Chinese.",
  "host_permissions": [
    "https://www.raidbots.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.raidbots.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "data/item-names.json"
      ],
      "matches": [
        "https://www.raidbots.com/*"
      ]
    }
  ]
}
